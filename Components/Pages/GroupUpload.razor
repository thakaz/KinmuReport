@page "/group-upload"
@attribute [Authorize(Roles = "グループ管理者,管理者")]
@using KinmuReport
@using KinmuReport.Services
@using KinmuReport.Models
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Options
@inject BulkUploadService BulkUpload
@inject ExcelParseService Parser
@inject CommuteParseService CommuteParser
@inject AttendanceContext Context
@inject LockService LockService
@inject SharePointService SharePoint
@inject IOptions<AppSettings> AppSettingsOptions

<PageTitle>グループ一括アップロード</PageTitle>

<h2 class="mb-4">
    <i class="bi bi-cloud-upload me-2"></i>グループ一括アップロード
</h2>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">Excelファイルを選択（複数選択可）</h5>
        <p class="text-muted small">勤務報告と通勤手当のファイルを混在してアップロードできます。ファイル種別は自動判定されます。</p>
        <InputFile OnChange="HandleFilesSelected" accept=".xlsx,.xlsm" multiple class="form-control" />
    </div>
</div>

@if (!string.IsNullOrEmpty(globalMessage))
{
    var alertClass = globalMessage.Contains("エラー") ? "alert-danger" : "alert-success";
    <div class="alert @alertClass alert-dismissible fade show" role="alert">
        <i class="bi @(globalMessage.Contains("エラー") ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill") me-1"></i>
        @globalMessage
        <button type="button" class="btn-close" @onclick="() => globalMessage = null"></button>
    </div>
}

@if (uploadItems.Count > 0)
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <i class="bi bi-files me-1"></i> ファイル一覧
            </h5>
            <div>
                <span class="badge bg-secondary me-2">@uploadItems.Count 件</span>
                <button class="btn btn-primary btn-sm me-2" @onclick="SaveAll" disabled="@isSaving">
                    <i class="bi bi-database-fill-add me-1"></i> すべて保存
                </button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="ClearAll" disabled="@isSaving">
                    <i class="bi bi-trash me-1"></i> クリア
                </button>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="list-group list-group-flush">
                @foreach (var item in uploadItems)
                {
                    <div class="list-group-item @GetItemClass(item)">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <div class="d-flex align-items-center mb-1">
                                    @if (item.FileType == BulkFileType.Attendance)
                                    {
                                        <i class="bi bi-calendar-check me-2 text-primary"></i>
                                    }
                                    else if (item.FileType == BulkFileType.Commute)
                                    {
                                        <i class="bi bi-train-front me-2 text-success"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-file-earmark-x me-2 text-danger"></i>
                                    }
                                    <strong>@item.FileName</strong>
                                </div>
                                <div class="small">
                                    @if (item.Status == BulkUploadStatus.Error)
                                    {
                                        <span class="text-danger">
                                            <i class="bi bi-x-circle me-1"></i>@item.ErrorMessage
                                        </span>
                                    }
                                    else if (!item.IsAuthorized && item.AuthErrorMessage != null)
                                    {
                                        <span class="text-danger">
                                            <i class="bi bi-shield-x me-1"></i>@item.AuthErrorMessage
                                        </span>
                                    }
                                    else if (item.IsLocked)
                                    {
                                        <span class="text-warning">
                                            <i class="bi bi-lock me-1"></i>@item.LockedBy がロック中
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">
                                            @GetFileTypeLabel(item.FileType) |
                                            @item.社員番号 @item.社員名 |
                                            @(item.対象年月?.GetYear())年@(item.対象年月?.GetMonth())月
                                        </span>
                                        @if (item.Status == BulkUploadStatus.Completed)
                                        {
                                            <span class="badge bg-success ms-2">保存完了</span>
                                        }
                                        else if (item.Status == BulkUploadStatus.Saving)
                                        {
                                            <span class="badge bg-info ms-2">保存中...</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary ms-2">準備完了</span>
                                        }
                                    }
                                </div>
                            </div>
                            <div>
                                @if (CanShowPreview(item))
                                {
                                    <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => TogglePreview(item)">
                                        <i class="bi @(selectedPreviewId == item.Id ? "bi-eye-slash" : "bi-eye")"></i>
                                    </button>
                                }
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveItem(item)" disabled="@isSaving">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* プレビュー表示 *@
    @if (selectedPreviewId != null)
    {
        var previewItem = uploadItems.FirstOrDefault(x => x.Id == selectedPreviewId);
        if (previewItem != null)
        {
            @if (previewItem.FileType == BulkFileType.Attendance && previewItem.AttendanceResult != null)
            {
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-table me-1"></i> 勤務報告プレビュー: @previewItem.社員番号 @previewItem.社員名
                        </h5>
                        <span class="badge bg-secondary">@previewItem.AttendanceResult.Value.勤怠リスト.Count 件</span>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover table-sm align-middle">
                                <thead class="table-dark">
                                    <tr>
                                        <th>勤務日</th>
                                        <th>出勤</th>
                                        <th>退勤</th>
                                        <th class="text-end">所定内</th>
                                        <th class="text-end">残業</th>
                                        <th class="text-end">深夜</th>
                                        <th class="text-end">合計</th>
                                        <th>区分</th>
                                        <th>備考</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in previewItem.AttendanceResult.Value.勤怠リスト.OrderBy(x => x.勤務日))
                                    {
                                        <tr>
                                            <td>@r.勤務日</td>
                                            <td>@r.出勤日時?.ToString("HH:mm")</td>
                                            <td>@r.退勤日時?.ToString("HH:mm")</td>
                                            <td class="text-end">@r.所定内時間</td>
                                            <td class="text-end">@r.残業時間</td>
                                            <td class="text-end">@r.深夜残業時間</td>
                                            <td class="text-end">@r.合計時間</td>
                                            <td>@r.勤怠区分</td>
                                            <td>@r.備考</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
            else if (previewItem.FileType == BulkFileType.Commute && previewItem.CommuteResult != null)
            {
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-train-front me-1"></i> 通勤手当プレビュー: @previewItem.社員番号 @previewItem.社員名
                        </h5>
                        <div>
                            <span class="badge bg-secondary me-2">@previewItem.CommuteResult.Value.通勤手当リスト.Count 件</span>
                            <span class="badge bg-success">
                                <i class="bi bi-currency-yen me-1"></i>合計 @previewItem.CommuteResult.Value.通勤手当リスト.Sum(x => x.金額 ?? 0).ToString("N0") 円
                            </span>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover table-sm align-middle">
                                <thead class="table-dark">
                                    <tr>
                                        <th>日付</th>
                                        <th>経路NO</th>
                                        <th class="text-end">金額</th>
                                        <th>備考</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in previewItem.CommuteResult.Value.通勤手当リスト.OrderBy(x => x.日付))
                                    {
                                        <tr>
                                            <td>@r.日付</td>
                                            <td>@r.経路NO</td>
                                            <td class="text-end">@r.金額?.ToString("N0")</td>
                                            <td>@r.備考</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        }
    }
}

@code {
    private List<BulkUploadItem> uploadItems = new();
    private string? globalMessage;
    private Guid? selectedPreviewId;
    private bool isSaving = false;

    private string currentUserId = "";
    private string currentRole = "";
    private string currentGroup = "";

    [CascadingParameter] Task<AuthenticationState> AuthState { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState;
        var user = authState.User;
        currentUserId = user.FindFirst(ClaimNames.EmployeeId)?.Value ?? "";
        currentRole = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
        currentGroup = user.FindFirst(ClaimNames.GroupCode)?.Value ?? "";
    }

    private async Task HandleFilesSelected(InputFileChangeEventArgs e)
    {
        globalMessage = null;

        foreach (var file in e.GetMultipleFiles(50))
        {
            try
            {
                using var stream = file.OpenReadStream(maxAllowedSize: AppSettingsOptions.Value.MaxUploadSizeBytes);
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                var fileBytes = ms.ToArray();

                var item = BulkUpload.ParseFile(fileBytes, file.Name);

                // 権限チェック
                if (item.Status == BulkUploadStatus.Parsed)
                {
                    await BulkUpload.CheckAuthorizationAsync(item, Context, currentRole, currentGroup);

                    // ロックチェック（勤務報告のみ）
                    if (item.IsAuthorized)
                    {
                        await BulkUpload.CheckLockAsync(item, LockService, currentUserId);
                    }
                }

                uploadItems.Add(item);
            }
            catch (Exception ex)
            {
                uploadItems.Add(new BulkUploadItem
                {
                    FileName = file.Name,
                    Status = BulkUploadStatus.Error,
                    ErrorMessage = ex.Message
                });
            }
        }
    }

    private async Task SaveAll()
    {
        isSaving = true;
        int successCount = 0;
        int errorCount = 0;

        foreach (var item in uploadItems.Where(CanSave))
        {
            item.Status = BulkUploadStatus.Saving;
            StateHasChanged();

            try
            {
                if (item.FileType == BulkFileType.Attendance)
                {
                    await SaveAttendance(item);
                }
                else if (item.FileType == BulkFileType.Commute)
                {
                    await SaveCommute(item);
                }

                item.Status = BulkUploadStatus.Completed;
                successCount++;
            }
            catch (Exception ex)
            {
                item.Status = BulkUploadStatus.Error;
                item.ErrorMessage = $"保存エラー: {ex.Message}";
                errorCount++;
            }

            StateHasChanged();
        }

        isSaving = false;

        if (errorCount == 0)
        {
            globalMessage = $"{successCount}件を保存しました。";
        }
        else
        {
            globalMessage = $"{successCount}件を保存、{errorCount}件でエラーが発生しました。";
        }
    }

    private async Task SaveAttendance(BulkUploadItem item)
    {
        if (item.AttendanceResult == null || item.FileBytes == null) return;

        var (社員番号, 対象年月, 勤怠リスト) = item.AttendanceResult.Value;

        // 既存データ削除
        await Context.勤怠s
            .Where(k => k.社員番号 == 社員番号 && k.対象年月 == 対象年月)
            .ExecuteDeleteAsync();

        Context.ChangeTracker.Clear();

        // 新データ追加
        Context.勤怠s.AddRange(勤怠リスト);

        // SharePointにアップロード
        var (folderPath, fileName) = SharePoint.GetReportPath(社員番号, 対象年月);
        using var uploadStream = new MemoryStream(item.FileBytes);
        var version = await SharePoint.UploadAsync(folderPath, fileName, uploadStream);

        // アップロード履歴を登録/更新
        var history = await Context.アップロード履歴s
            .FirstOrDefaultAsync(h => h.社員番号 == 社員番号 && h.対象年月 == 対象年月);

        if (history == null)
        {
            history = new アップロード履歴
            {
                社員番号 = 社員番号,
                対象年月 = 対象年月,
                アップロード日時 = DateTime.Now,
                sp版数 = version
            };
            Context.アップロード履歴s.Add(history);
        }
        else
        {
            history.アップロード日時 = DateTime.Now;
            history.sp版数 = version;
            Context.アップロード履歴s.Update(history);
        }

        await Context.SaveChangesAsync();
    }

    private async Task SaveCommute(BulkUploadItem item)
    {
        if (item.CommuteResult == null) return;

        var (社員番号, _, 対象年月, 通勤手当リスト) = item.CommuteResult.Value;

        // 既存データ削除
        await Context.通勤手当s
            .Where(k => k.社員番号 == 社員番号 && k.対象年月 == 対象年月)
            .ExecuteDeleteAsync();

        Context.ChangeTracker.Clear();

        // 新データ追加
        Context.通勤手当s.AddRange(通勤手当リスト);
        await Context.SaveChangesAsync();
    }

    private void RemoveItem(BulkUploadItem item)
    {
        uploadItems.Remove(item);
        if (selectedPreviewId == item.Id)
            selectedPreviewId = null;
    }

    private void ClearAll()
    {
        uploadItems.Clear();
        selectedPreviewId = null;
        globalMessage = null;
    }

    private void TogglePreview(BulkUploadItem item)
    {
        selectedPreviewId = selectedPreviewId == item.Id ? null : item.Id;
    }

    private bool CanSave(BulkUploadItem item)
    {
        return item.Status == BulkUploadStatus.Parsed
            && item.IsAuthorized
            && !item.IsLocked;
    }

    private bool CanShowPreview(BulkUploadItem item)
    {
        return item.Status == BulkUploadStatus.Parsed || item.Status == BulkUploadStatus.Completed;
    }

    private string GetItemClass(BulkUploadItem item)
    {
        if (item.Status == BulkUploadStatus.Error || !item.IsAuthorized)
            return "list-group-item-danger";
        if (item.IsLocked)
            return "list-group-item-warning";
        if (item.Status == BulkUploadStatus.Completed)
            return "list-group-item-success";
        return "";
    }

    private string GetFileTypeLabel(BulkFileType type) => type switch
    {
        BulkFileType.Attendance => "勤務報告",
        BulkFileType.Commute => "通勤手当",
        _ => "不明"
    };
}
